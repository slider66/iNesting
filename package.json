{
  "name": "inesting",
  "version": "1.1.0",
  "description": "Nesting for CNC 2D machines — updated fork of Deepnest by Jack Qiao",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "test": "node test/test-dxf.js && node test/test-load.js",
    "package": "electron-packager . iNesting --platform=win32 --arch=x64 --out=dist --overwrite --ignore=^/dist --ignore=^/test --ignore=^/.git --ignore=^/node_modules/electron-builder --ignore=^/node_modules/@electron/rebuild --ignore=^/node_modules/@electron/packager --icon=icon.ico",
    "configure": "node-gyp configure --release",
    "build": "node-gyp rebuild --target=1.4.8 --arch=x64 --dist-url=https://atom.io/download/atom-shell",
    "clean": "node-gyp clean configure build --verbose --target=1.4.8 --arch=ia32 --dist-url=https://atom.io/download/atom-shell",
    "pack": "build --dir",
    "dist": "build"
  },
  "repository": "https://github.com/slider66/iNesting",
  "keywords": [
    "Electron",
    "Nesting",
    "CNC",
    "Laser"
  ],
  "author": {
    "name": "Jack Qiao",
    "email": "jak000@gmail.com",
    "url": "http://deepnest.io"
  },
  "devDependencies": {
    "@electron/packager": "^20.0.1",
    "@electron/rebuild": "^3.6.0",
    "electron": "^29.4.6",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "@electron/remote": "^2.1.3",
    "dxf": "^5.3.1",
    "electron-settings": "^4.0.4",
    "filequeue": "^0.5.0",
    "graceful-fs": "^4.2.11",
    "melanke-watchjs": "^1.3.1",
    "nan": "^2.22.0",
    "paralleljs": "^0.2.1",
    "request": "^2.88.2",
    "write-file-queue": "0.0.1"
  },
  "build": {
    "appId": "io.inesting.app",
    "productName": "iNesting",
    "copyright": "Copyright 2016 Jack Qiao. iNesting fork by slider66.",
    "compression": "normal",
    "nodeGypRebuild": false,
    "asar": true,
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "main/**/*",
      "minkowski/**/*",
      "icons/**/*",
      "icon.ico",
      "icon.icns",
      "node_modules/**/*",
      "!node_modules/electron/**",
      "!node_modules/electron-builder/**",
      "!node_modules/@electron/rebuild/**",
      "!**/*.md",
      "!test/**"
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "icon": "icon.icns"
    },
    "win": {
      "icon": "icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
